rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      // Allow write if it's the user's own profile or a mock profile
      allow write: if request.auth != null && (request.auth.uid == userId || userId.matches('^mock_.*'));
    }

    // Wishlist entries
    match /wishlistEntries/{entryId} {
      allow read: if request.auth != null;
      // Allow create/update/delete for own entries or mock entries
      allow create: if request.auth != null && (request.resource.data.userId == request.auth.uid || entryId.matches('^mock_.*'));
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || entryId.matches('^mock_.*'));
    }

    // Groups
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && (request.auth.uid in resource.data.members || groupId.matches('^mock_.*'));

      // Group Chatroom Messages (nested match)
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
